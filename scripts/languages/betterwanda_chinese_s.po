msgid "Charged Alarming Clock"
msgstr "充能的警钟"

#. STRINGS.NAMES.WATCH_CONTAINER
msgctxt "STRINGS.NAMES.WATCH_CONTAINER"
msgid "Watch Box"
msgstr "怀表盒"

#. STRINGS.RECIPE_DESC.WATCH_CONTAINER
msgctxt "STRINGS.RECIPE_DESC.WATCH_CONTAINER"
msgid "It will store the watch very well"
msgstr "它可以很好地储存怀表"

#. STRINGS.CHARACTERS.GENERIC.DESCRIBE.WATCH_CONTAINER
msgctxt "STRINGS.CHARACTERS.GENERIC.DESCRIBE.WATCH_CONTAINER"
msgid "A container for pocket watches."
msgstr "怀表的容器。"

#. STRINGS.CHARACTERS.WILLOW.DESCRIBE.WATCH_CONTAINER
msgctxt "STRINGS.CHARACTERS.WILLOW.DESCRIBE.WATCH_CONTAINER"
